# Agent backend selection: "ollama" for local, "gemini" for cloud
VITE_AGENT_BACKEND="ollama"
VITE_OLLAMA_MODEL="mistral"

# Gemini (optional, for fallback)
GEMINI_API_KEY="not_needed_for_local"

# AWS S3 (optional)
S3_BUCKET=""
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Server config
SESSION_SECRET="dev_secret_change_me"
NODE_ENV="development"

# Enable Ollama CORS if needed
OLLAMA_ORIGINS="*"
