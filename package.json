{
  "name": "gopilot-monorepo",
  "private": true,
  "workspaces": [
    "apps/industrial-control"
  ],
  "scripts": {
    "build": "npm --workspace apps/industrial-control run build",
    "dev": "npm --workspace apps/industrial-control run dev",
    "build:industrial-control": "npm --workspace apps/industrial-control run build",
    "dev:industrial-control": "npm --workspace apps/industrial-control run dev",
    "clean": "rimraf node_modules apps/*/node_modules apps/*/dist apps/*/build .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "firebase-admin": "^14.0.0"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
